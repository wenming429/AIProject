# LumenIM Environment Configuration Template
# Copy this file to .env and modify as needed

# Server Configuration
HTTP_ADDR=:9501
WEBSOCKET_ADDR=:9502
TCP_ADDR=:9505

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_USER=root
DB_PASSWORD=wenming429
DB_NAME=go_chat
DB_COLLATION=utf8mb4_general_ci

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_AUTH=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=836c3fea9bba4e04d51bd0fbcc5
JWT_EXPIRES_TIME=3600
JWT_BUFFER_TIME=3600

# CORS Configuration
CORS_ORIGIN=*
CORS_METHODS=OPTIONS,GET,POST,PUT,DELETE
CORS_CREDENTIALS=false

# File System Configuration
FS_DEFAULT=minio
FS_LOCAL_ROOT=/work/
FS_MINIO_SECRET_ID=minioadmin
FS_MINIO_SECRET_KEY=minioadmin
FS_MINIO_BUCKET_PUBLIC=im-static
FS_MINIO_BUCKET_PRIVATE=im-private
FS_MINIO_ENDPOINT=localhost:9000
FS_MINIO_SSL=false

# Email Configuration
EMAIL_HOST=smtp.163.com
EMAIL_PORT=465
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROMNAME=Lumen IM

# App Environment
APP_ENV=dev
APP_DEBUG=false
