# Electron 桌面端环境配置

# API服务器地址
VITE_BASE_API=http://127.0.0.1:9501
VITE_SOCKET_API=ws://127.0.0.1:9502

# 应用配置
VITE_APP_TITLE=LumenIM
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=企业级即时通讯系统

# 功能开关
VITE_ENABLE_NOTIFICATION=true
VITE_ENABLE_AUTO_UPDATE=false
VITE_ENABLE_CRASH_REPORTER=false

# 调试配置
VITE_DEBUG=false

# Electron 必须使用 hash 路由模式（file:// 协议不支持 history 模式）
VITE_ROUTER_MODE=hash
VITE_BASE=./
