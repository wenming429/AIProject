# Electron 桌面应用环境配置

ENV = 'production'

# 基础路径 - Electron 使用 hash 路由模式
VITE_BASE=./

# 路由模式 - Electron 中使用 hash 模式避免刷新问题
VITE_ROUTER_MODE=hash

# API 地址 - 根据实际情况修改
VITE_BASE_API=http://127.0.0.1:9501

# WebSocket 地址
VITE_SOCKET_API=ws://127.0.0.1:9502

# RSA 公钥
