# ============================================================
# LumenIM 生产环境配置
# ============================================================
# 此文件用于生产服务器部署
# 构建命令: npm run build
# ============================================================

ENV = 'production'

VITE_BASE=/
VITE_ROUTER_MODE=history

# 生产环境 API 地址 - 请根据实际生产服务器修改
VITE_BASE_API=https://your-domain.com
VITE_SOCKET_API=wss://your-domain.com

# 媒体资源域名（可选）- 用于图片、音频、视频等资源的访问
# 如果与 VITE_BASE_API 相同，可以不配置此项
# 示例: https://cdn.your-domain.com
# VITE_MEDIA_URL=https://your-domain.com

VITE_APP_NAME=LumenIM
VITE_APP_ENV=production
