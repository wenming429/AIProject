{
  "name": "lumenim",
  "private": true,
  "version": "1.0.0",
  "description": "LumenIM - 企业级即时通讯系统",
  "author": "LumenIM Team",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build --mode production",
    "build:electron": "vite build --mode electron",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src/**/*.{vue,ts,tsx} --fix",
    "format": "prettier --write src/",

    "electron:dev": "cross-env NODE_ENV=development concurrently -k \"vite --mode electron --port 5174\" \"wait-on http://localhost:5174 && cross-env PORT=5174 NODE_ENV=development electron .\"",
    "electron:build": "npm run build:electron && electron-builder --config electron-builder.json",
    "electron:build:win": "npm run build:electron && electron-builder --config electron-builder.json --win",
    "electron:build:mac": "npm run build:electron && electron-builder --config electron-builder.json --mac",
    "electron:build:linux": "npm run build:electron && electron-builder --config electron-builder.json --linux",
    "electron:build:all": "npm run build:electron && electron-builder --config electron-builder.json --win --mac --linux"
  },
  "dependencies": {
    "@highlightjs/vue-plugin": "^2.1.0",
    "@vueuse/core": "^13.1.0",
    "core-js": "^3.39.0",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "highlight.js": "^11.5.0",
    "js-audio-recorder": "^1.0.7",
    "jsencrypt": "^3.3.2",
    "lru-cache": "^11.0.2",
    "md-editor-v3": "^5.6.1",
    "pinia": "^3.0.2",
    "pinia-plugin-persistedstate": "^4.2.0",
    "quill": "^2.0.3",
    "quill-mention": "^6.1.1",
    "snappyjs": "^0.7.0",
    "uuid": "^11.1.0",
    "vue": "^3.5.16",
    "vue-cropper": "^1.1.3",
    "vue-draggable-plus": "^0.6.0",
    "vue-router": "^4.5.1",
    "xgplayer": "^3.0.21"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@eslint/js": "^9.28.0",
    "@icon-park/vue-next": "^1.4.2",
    "@rushstack/eslint-patch": "^1.3.3",
    "@tsconfig/node18": "^18.2.2",
    "@types/node": "^20.11.1",
    "@types/sortablejs": "^1.15.0",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-vue": "^10.2.0",
    "globals": "^16.2.0",
    "less": "^4.3.0",
    "naive-ui": "^2.41.0",
    "prettier": "^3.5.3",
    "typescript": "~5.2.0",
    "typescript-eslint": "^8.33.1",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.3.5",
    "vite-plugin-compression": "^0.5.1",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^2.2.8",
    "wait-on": "^8.0.3",
    "yaml": "^2.8.1"
  }
}
