			"name": "1. 健康检查",
			"item": [
				{
					"name": "健康检查",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('状态码为200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('响应时间小于500ms', function() {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});",
									"pm.test('返回JSON格式', function() {",
									"    pm.response.to.be.json();",
									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "2. 用户认证",
			"item": [
				{
					"name": "2.1 用户注册 - 有效参数",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('状态码为200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('返回成功标识', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.code).to.eql(200);",
									"});",
									"pm.test('保存用户ID', function() {",
									"    var jsonData = pm.response.json();",
									"    if(jsonData.data && jsonData.data.id) {",
									"        pm.collectionVariables.set('userId', jsonData.data.id);",
									"    }",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser{{$timestamp}}\",\n    \"password\": \"Test123456\",\n    \"nickname\": \"测试用户\",\n    \"email\": \"test{{$timestamp}}@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/user/register",
							"host": ["{{baseUrl}}"],
							"path": ["user", "register"]
						}
					}
				},
