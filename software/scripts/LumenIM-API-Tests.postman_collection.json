							"listen": "test",
							"script": {
								"exec": [
									"pm.test('状态码为200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test('返回token', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('token');",
